{
  "name": "@parthj/diffdeck",
  "version": "0.3.8",
  "description": "Open git diffs in browser, add comments & send all to agent",
  "type": "module",
  "packageManager": "bun@1.3.3",
  "bin": {
    "diffdeck": "./dist/server/cli.js"
  },
  "main": "./dist/server/cli.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "bun run build:client && bun run build:server",
    "build:client": "vite build",
    "build:server": "tsc -p tsconfig.server.json",
    "check": "bun run typecheck && bun run lint && bun run format:check && bun run build",
    "dev": "./scripts/dev.sh",
    "dev:setup": "./scripts/setup-fake-repo.sh",
    "dev:reset": "REBUILD_FAKE_REPO=1 ./scripts/dev.sh",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "lint": "oxlint . --react-plugin --deny-warnings",
    "pack:dry-run": "npm pack --dry-run",
    "prepack": "bun run build",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.server.json --noEmit"
  },
  "keywords": [
    "diff",
    "git",
    "cli",
    "browser"
  ],
  "author": "Parth Jadhav",
  "license": "MIT",
  "homepage": "https://github.com/ParthJadhav/DiffDeck#readme",
  "bugs": {
    "url": "https://github.com/ParthJadhav/DiffDeck/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ParthJadhav/DiffDeck.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@pierre/diffs": "^1.1.20",
    "@pierre/trees": "^1.0.0-beta.3",
    "@radix-ui/react-slot": "^1.2.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "express": "^5.1.0",
    "lucide-react": "^1.16.0",
    "open": "^10.1.2",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-resizable-panels": "^4.10.0",
    "react-virtuoso": "4.14.0",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "@tailwindcss/vite": "^4.2.4",
    "@types/express": "^5.0.3",
    "@types/node": "^24.9.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.1.0",
    "oxlint": "^1.62.0",
    "tailwindcss": "^4.2.4",
    "typescript": "^5.9.3",
    "vite": "^7.1.12"
  }
}
