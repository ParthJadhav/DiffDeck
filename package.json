{
  "name": "@parthjadhav/cli-diff",
  "version": "0.1.0",
  "description": "View git diffs in the browser with @pierre/diffs and @pierre/trees.",
  "type": "module",
  "packageManager": "bun@1.3.3",
  "bin": {
    "cli-diff": "./dist/server/cli.js"
  },
  "main": "./dist/server/cli.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "bun run build:client && bun run build:server",
    "build:client": "vite build",
    "build:server": "tsc -p tsconfig.server.json",
    "check": "bun run typecheck && bun run lint && bun run format:check && bun run build",
    "dev": "./scripts/dev.sh",
    "dev:setup": "./scripts/setup-fake-repo.sh",
    "dev:reset": "REBUILD_FAKE_REPO=1 ./scripts/dev.sh",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "pack:dry-run": "npm pack --dry-run",
    "prepack": "bun run build",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.server.json --noEmit"
  },
  "keywords": [
    "diff",
    "git",
    "cli",
    "browser"
  ],
  "author": "Parth Jadhav",
  "license": "MIT",
  "homepage": "https://github.com/ParthJadhav/cli-diff#readme",
  "bugs": {
    "url": "https://github.com/ParthJadhav/cli-diff/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ParthJadhav/cli-diff.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@pierre/diffs": "^1.1.20",
    "@pierre/trees": "^1.0.0-beta.3",
    "express": "^5.1.0",
    "open": "^10.1.2",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.2.4",
    "@types/express": "^5.0.3",
    "@types/node": "^24.9.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.1.0",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.2.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.1",
    "vite": "^7.1.12"
  }
}
